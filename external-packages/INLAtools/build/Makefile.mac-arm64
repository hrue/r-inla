CFLAGS = -framework Accelerate $(FLAGS) $(INC) -O3 -mtune=native -fopenmp  -fpic -I. -DINLA_EXTERNAL_PACKAGE
LDFLAGS = -framework Accelerate $(LIB)
TARGET = libINLAtools.so
OBJ = $(patsubst %.c,%.o,$(wildcard *.c))

$(TARGET) : $(OBJ)
	$(CC) $(LDFLAGS) -o $@ -dynamiclib $^ -lgfortran -Wl,--whole-archive -lgomp -Wl,--no-whole-archive $(LIBLTDL) -lm

clean :; rm -f $(TARGET) $(OBJ)

gcc -shared -fPIC -o libmylib.so mylib.c 
