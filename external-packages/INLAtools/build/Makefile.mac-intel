CFLAGS = -framework Accelerate $(INC) -O3 -mtune=generic -fopenmp  -fpic -I. -DINLA_EXTERNAL_PACKAGE
LDFLAGS = -framework Accelerate $(LIB)
TARGET = libINLAtools.so
OBJ = $(patsubst %.c,%.o,$(wildcard *.c))

$(TARGET) : $(OBJ)
	$(CC) $(LDFLAGS) -o $@ -dynamiclib $^ $(LIBBLAS) -lgfortran -lgomp $(LIBLTDL) -lm

 clean :; rm -f $(TARGET) $(OBJ)

