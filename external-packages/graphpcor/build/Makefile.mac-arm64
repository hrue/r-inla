CFLAGS = -framework Accelerate $(FLAGS) -O3 -mtune=native -fopenmp  -fpic -I.
LDFLAGS = -framework Accelerate
TARGET = libgraphpcor.so
OBJ = $(patsubst %.c,%.o,$(wildcard *.c))

$(TARGET) : $(OBJ)
	$(CC) $(LDFLAGS) -o $@ -dynamiclib $^ -lgfortran -lgomp  $(LIBR) $(LIBLTDL) -lm

 clean :; rm -f $(TARGET) $(OBJ)

